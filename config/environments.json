{
  "dev": {
    "name": "Development",
    "envId": 2,
    "relay": {
      "port": 3000,
      "url": "ws://localhost:3000",
      "pm2Name": "estelle-relay-dev"
    },
    "pylon": {
      "pylonIndex": "1",
      "relayUrl": "ws://localhost:3000",
      "pm2Name": "estelle-pylon-dev",
      "configDir": "~/.claude-release",
      "credentialsBackupDir": "~/.claude-credentials/release",
      "mcpPort": 9878,
      "dataDir": "./dev-data",
      "defaultWorkingDir": "C:\\WorkSpace"
    },
    "client": {
      "port": 5173,
      "pm2Name": "estelle-client-dev",
      "title": "Estelle (dev)"
    },
    "archive": {
      "port": 3009,
      "root": "/home/estelle/archive",
      "pm2Name": "estelle-archive-dev"
    }
  },
  "stage": {
    "name": "Staging",
    "envId": 1,
    "relay": {
      "port": 8080,
      "url": "wss://YOUR_SERVER_IP:8080",
      "flyApp": "estelle-relay-v2-stage"
    },
    "pylon": {
      "pylonIndex": "1",
      "relayUrl": "wss://YOUR_SERVER_IP:8080",
      "pm2Name": "estelle-pylon-stage",
      "configDir": "~/.claude-release",
      "credentialsBackupDir": "~/.claude-credentials/release",
      "mcpPort": 9877,
      "dataDir": "./stage-data/data",
      "defaultWorkingDir": "C:\\WorkSpace"
    },
    "client": {
      "title": "Estelle"
    },
    "archive": {
      "port": 3009,
      "root": "/home/estelle/archive"
    }
  },
  "release": {
    "name": "Production",
    "envId": 0,
    "relay": {
      "port": 8080,
      "url": "ws://YOUR_SERVER_IP:8080"
    },
    "pylon": {
      "pylonIndex": "1",
      "relayUrl": "ws://YOUR_SERVER_IP:8080",
      "pm2Name": "estelle-pylon",
      "configDir": "~/.claude-release",
      "credentialsBackupDir": "~/.claude-credentials/release",
      "mcpPort": 9876,
      "dataDir": "./release-data/data",
      "defaultWorkingDir": "C:\\WorkSpace"
    },
    "client": {
      "title": "Estelle"
    },
    "archive": {
      "port": 3009,
      "root": "/home/estelle/archive"
    }
  }
}
